# ── OpenRouter（所有 AI 能力共用同一个 key）──
OPENROUTER_API_KEY=sk-or-xxxxxx
OPENROUTER_BASE=https://openrouter.ai/api/v1

# ── LLM 文案生成模型 ──
# 中文梗类创作 deepseek 性价比高；更强可换 anthropic/claude-sonnet-latest
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# ── AI 生图模型 ──
# pipeline/imagegen.py 使用（magic 流水线 gen: 前缀镜头）
IMAGE_MODEL=google/gemini-2.5-flash-image

# ── AI 图生视频模型 ──
# pipeline/videogen.py 使用（magic 流水线 animate: true 镜头）
# 候选：google/veo-3.1-lite($0.03/s) / alibaba/wan-2.6($0.10/s) / kwaivgi/kling-v3.0-std($0.084/s)
VIDEO_MODEL=google/veo-3.1-lite
VIDEO_RESOLUTION=720p
VIDEO_ASPECT=9:16
